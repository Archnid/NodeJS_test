<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="NexaTech 致力于为全球企业提供安全、智能、高效的技术解决方案，从云计算到人工智能，助力数字化转型。">
  <meta name="theme-color" content="#4f46e5">
  <!-- Open Graph / 微信 & 社交分享预览 -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="NexaTech - 驱动未来科技">
  <meta property="og:description" content="用科技的力量驱动未来无限可能。为全球企业提供云计算、AI、数据分析等技术解决方案。">
  <meta property="og:image" content="https://via.placeholder.com/1200x630/4f46e5/ffffff?text=NexaTech">
  <meta property="og:site_name" content="NexaTech">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="NexaTech - 驱动未来科技">
  <meta name="twitter:description" content="用科技的力量驱动未来无限可能。">
  <meta name="twitter:image" content="https://via.placeholder.com/1200x630/4f46e5/ffffff?text=NexaTech">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- ====== 导航栏 ====== -->
  <nav class="navbar" id="navbar">
    <div class="container nav-container">
      <a href="#" class="logo">
        <span class="logo-icon">◆</span> NexaTech
      </a>
      <ul class="nav-links">
        <li><a href="#hero">首页</a></li>
        <li><a href="#features">服务</a></li>
        <li><a href="#stats">关于</a></li>
        <li><a href="#team">团队</a></li>
        <li><a href="#contact" class="btn-nav">联系我们</a></li>
      </ul>
      <button class="menu-toggle" id="menuToggle" aria-label="菜单">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ====== Hero 主视觉 ====== -->
  <section class="hero" id="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <span class="hero-tag">新一代企业级解决方案</span>
      <h1>用科技的力量<br><span class="gradient-text">驱动未来无限可能</span></h1>
      <p class="hero-desc">NexaTech 致力于为全球企业提供安全、智能、高效的技术解决方案。<br>从云计算到人工智能，我们帮助您实现数字化转型的每一步。</p>
      <div class="hero-actions">
        <a href="#features" class="btn btn-primary">探索服务</a>
        <a href="#contact" class="btn btn-outline">预约演示</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>向下滚动</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- ====== 核心服务 ====== -->
  <section class="section features" id="features">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">核心服务</span>
        <h2>全方位技术赋能您的业务</h2>
        <p>我们提供从基础设施到应用层的一站式技术服务，助力企业在数字时代保持领先。</p>
      </div>
      <div class="features-grid" id="featuresGrid">
        <!-- JS 动态渲染 -->
      </div>
    </div>
  </section>

  <!-- ====== 数据统计 ====== -->
  <section class="section stats" id="stats">
    <div class="container">
      <div class="section-header light">
        <span class="section-tag">关于我们</span>
        <h2>值得信赖的技术伙伴</h2>
        <p>自创立以来，我们始终以技术创新为核心驱动力，服务遍布全球。</p>
      </div>
      <div class="stats-grid" id="statsGrid">
        <!-- JS 动态渲染 -->
      </div>
    </div>
  </section>

  <!-- ====== 团队成员 ====== -->
  <section class="section team" id="team">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">核心团队</span>
        <h2>由行业精英组成的领导团队</h2>
        <p>汇聚来自全球顶尖科技公司的资深专家，用丰富经验引领产品方向。</p>
      </div>
      <div class="team-grid" id="teamGrid">
        <!-- JS 动态渲染 -->
      </div>
    </div>
  </section>

  <!-- ====== 联系我们 ====== -->
  <section class="section contact" id="contact">
    <div class="container">
      <div class="contact-wrapper">
        <div class="contact-info">
          <span class="section-tag">联系我们</span>
          <h2>开启您的数字化之旅</h2>
          <p>无论您有任何问题或合作意向，都欢迎随时联系我们。团队将在 24 小时内回复。</p>
          <div class="contact-details">
            <div class="contact-item">
              <span class="contact-icon">📧</span>
              <div>
                <strong>电子邮件</strong>
                <p>contact@nexatech.com</p>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">📞</span>
              <div>
                <strong>联系电话</strong>
                <p>400-888-9999</p>
              </div>
            </div>
            <div class="contact-item">
              <span class="contact-icon">📍</span>
              <div>
                <strong>公司地址</strong>
                <p>北京市海淀区中关村科技园 A 座 18 层</p>
              </div>
            </div>
          </div>
        </div>
        <form class="contact-form" id="contactForm">
          <div class="form-group">
            <label for="name">姓名</label>
            <input type="text" id="name" name="name" placeholder="请输入您的姓名" required>
          </div>
          <div class="form-group">
            <label for="email">邮箱</label>
            <input type="email" id="email" name="email" placeholder="请输入您的邮箱" required>
          </div>
          <div class="form-group">
            <label for="message">留言</label>
            <textarea id="message" name="message" rows="5" placeholder="请描述您的需求..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full">提交留言</button>
          <div class="form-status" id="formStatus"></div>
        </form>
      </div>
    </div>
  </section>

  <!-- ====== 页脚 ====== -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="#" class="logo"><span class="logo-icon">◆</span> NexaTech</a>
          <p>用科技的力量驱动未来无限可能。</p>
        </div>
        <div class="footer-links">
          <h4>产品服务</h4>
          <a href="#">云计算平台</a>
          <a href="#">AI 解决方案</a>
          <a href="#">数据分析</a>
          <a href="#">安全服务</a>
        </div>
        <div class="footer-links">
          <h4>关于我们</h4>
          <a href="#">公司介绍</a>
          <a href="#">加入我们</a>
          <a href="#">新闻动态</a>
          <a href="#">合作伙伴</a>
        </div>
        <div class="footer-links">
          <h4>支持</h4>
          <a href="#">帮助中心</a>
          <a href="#">开发文档</a>
          <a href="#">服务状态</a>
          <a href="#">隐私政策</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 NexaTech. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
